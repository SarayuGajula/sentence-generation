<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cs4485.sentencebuilder.controller.AutoCompleteTabController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox spacing="12">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

        <Label text="Type a sentence — press Space after each word to see next-word suggestions:"/>
        <TextArea fx:id="autocompleteInput" prefHeight="100" wrapText="true"
                  promptText="Start typing here…"/>

        <Label text="Suggestions for next word:" style="-fx-font-weight: bold;"/>
        <ListView fx:id="suggestionsList" prefHeight="160"/>

        <HBox spacing="8">
            <Button fx:id="useSuggestionButton" text="Use Selected Word" onAction="#onUseSuggestion" prefWidth="150"/>
            <Button fx:id="clearAutocompleteButton" text="Clear" onAction="#onClearAutocomplete" prefWidth="80"/>
        </HBox>
    </VBox>
</AnchorPane>
