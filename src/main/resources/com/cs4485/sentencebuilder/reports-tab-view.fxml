<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cs4485.sentencebuilder.controller.ReportsTabController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox spacing="12">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

        <Label text="Generated Sentences History:" style="-fx-font-weight: bold;"/>

        <TableView fx:id="sentencesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="sentenceCol"     text="Sentence"      prefWidth="480"/>
                <TableColumn fx:id="sentenceAlgoCol" text="Algorithm"     prefWidth="160"/>
                <TableColumn fx:id="sentenceDateCol" text="Generated At"  prefWidth="180"/>
            </columns>
            <placeholder><Label text="No sentences generated yet."/></placeholder>
        </TableView>
    </VBox>
</AnchorPane>
