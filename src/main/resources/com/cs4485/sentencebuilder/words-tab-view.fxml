<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cs4485.sentencebuilder.controller.WordsTabController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox spacing="12">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Sort by:"/>
            <ComboBox fx:id="wordSortCombo" prefWidth="220" onAction="#onSortWords"/>
            <Button text="Refresh" onAction="#onRefreshWords" prefWidth="80"/>
        </HBox>

        <TableView fx:id="wordsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="wordCol"       text="Word"           prefWidth="200"/>
                <TableColumn fx:id="totalCountCol" text="Total Count"    prefWidth="120"/>
                <TableColumn fx:id="startCountCol" text="Sentence Start" prefWidth="130"/>
                <TableColumn fx:id="endCountCol"   text="Sentence End"   prefWidth="130"/>
            </columns>
            <placeholder><Label text="No words loaded. Import a file first."/></placeholder>
        </TableView>
    </VBox>

</AnchorPane>
